---
const navLinks = [
  { href: '/#uslugi', label: 'Usługi' },
  { href: '/#technologia', label: 'Technologia' },
  { href: '/aktualnosci', label: 'Aktualności' },
];
---
<nav class="nav">
  <div class="nav-logo">
    <a href="/">
