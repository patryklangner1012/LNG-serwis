    </a>
    <span class="nav-pill">Serwis</span>
  </div>
  <div class="nav-links">
    {navLinks.map(l => <a href={l.href}>{l.label}</a>)}
    <a href="https://transport-lng.pl" target="_blank" rel="noopener" class="nav-transport">↗ Transport LNG</a>
    <a href="/#kontakt" class="nav-cta">Kontakt</a>
  </div>
  <button class="nav-burger" id="burger" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<style>
.nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 48px;
  height: 72px;
  background: #fff;
  border-bottom: 1px solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 100;
}
.nav-logo { display: flex; align-items: center; gap: 10px; }
.nav-pill {
  font-size: 10px; font-weight: 600; letter-spacing: .08em;
  text-transform: uppercase; background: #00A0E3; color: #fff;
  padding: 3px 10px; border-radius: 20px;
}
.nav-links { display: flex; gap: 28px; align-items: center; }
.nav-links a { color: #555; font-size: 13px; text-decoration: none; transition: color .2s; }
.nav-links a:hover { color: #00A0E3; }
.nav-transport {
  color: #00A0E3 !important;
  font-size: 12px !important;
  border: 1px solid rgba(0,160,227,.3);
  padding: 6px 14px;
  border-radius: 6px;
}
.nav-cta {
  background: #0f0f1a !important;
  color: #fff !important;
  padding: 9px 20px;
  border-radius: 7px;
  font-weight: 600 !important;
  font-size: 13px !important;
}
.nav-cta:hover { opacity: .85; }
.nav-burger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
}
.nav-burger span {
  display: block; width: 22px; height: 2px; background: #0f0f1a; border-radius: 2px;
}
@media (max-width: 768px) {
  .nav { padding: 0 20px; }
  .nav-links { display: none; }
  .nav-burger { display: flex; }
}
</style>
