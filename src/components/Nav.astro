---
interface Props {
  lang?: 'pl' | 'en' | 'de';
}
const { lang = 'pl' } = Astro.props;

const base     = lang === 'en' ? '/en' : lang === 'de' ? '/de' : '';
const newsHref = lang === 'en' ? '/en/news' : lang === 'de' ? '/de/news' : '/aktualnosci';
const homeHref = lang === 'en' ? '/en' : lang === 'de' ? '/de' : '/';

const t = {
  subtitle: lang === 'en' ? 'Cryogenic Service'    : lang === 'de' ? 'Kryogener Service'   : 'Serwis kriogeniczny',
  services: lang === 'en' ? 'Services'             : lang === 'de' ? 'Leistungen'           : 'Usługi',
  tech:     lang === 'en' ? 'Technology'           : lang === 'de' ? 'Technologie'          : 'Technologia',
  gallery:  lang === 'en' ? 'Gallery'              : lang === 'de' ? 'Galerie'              : 'Galeria',
  news:     lang === 'en' ? 'News'                 : lang === 'de' ? 'Aktuelles'            : 'Aktualności',
  contact:  lang === 'en' ? 'Contact'              : lang === 'de' ? 'Kontakt'              : 'Kontakt',
  login:    lang === 'en' ? 'Log in'               : lang === 'de' ? 'Anmelden'             : 'Zaloguj się',
};
---

<header class="nav-wrap">
  <nav class="nav">
    <a href={homeHref} class="nav-logo" aria-label="LNG Best Partner Serwis">
      <img src="/images/logo.svg" alt="LNG Best Partner Sp. z o.o." class="logo-img" />
      <span class="nav-divider"></span>
      <span class="nav-subtitle">{t.subtitle}</span>
    </a>

    <div class="nav-links" id="nav-links">
      <a href={`${base}/#uslugi`}>{t.services}</a>
      <a href={`${base}/#technologia`}>{t.tech}</a>
      <a href={`${base}/#galeria`}>{t.gallery}</a>
      <a href={newsHref}>{t.news}</a>
      <a href="https://transport-lng.pl" target="_blank" rel="noopener" class="nav-tr">↗ Transport LNG</a>
      <a href={`${base}/#kontakt`} class="nav-ct">{t.contact}</a>
      <a href="https://app.lng.best" class="nav-login">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        {t.login}
      </a>

      <div class="lang-switcher">
        <a href="/" class={`lang-btn${lang === 'pl' ? ' lang-active' : ''}`} aria-label="Polski">🇵🇱</a>
        <a href="/en" class={`lang-btn${lang === 'en' ? ' lang-active' : ''}`} aria-label="English">🇬🇧</a>
        <a href="/de" class={`lang-btn${lang === 'de' ? ' lang-active' : ''}`} aria-label="Deutsch">🇩🇪</a>
      </div>
    </div>

    <button class="nav-burger" id="burger" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </nav>
</header>

<script>
  const burger = document.getElementById('burger');
  const links  = document.getElementById('nav-links');
  burger?.addEventListener('click', () => {
    const open = links?.classList.toggle('open');
    burger.setAttribute('aria-expanded', String(!!open));
  });
</script>

<style>
.nav-wrap {
  position: sticky; top: 0; z-index: 100;
  background: #fff; border-bottom: 1px solid #f0f0f0;
}
.nav {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 6%; height: 72px; max-width: 1600px; margin: 0 auto;
}
.nav-logo {
  display: flex; align-items: center; gap: 0;
  text-decoration: none; flex-shrink: 0;
}
.logo-img { height: 36px; width: auto; display: block; }
.nav-divider {
  display: inline-block; width: 1px; height: 30px;
  background: #e8e8e8; margin: 0 18px;
}
.nav-subtitle {
  font-size: 11px; font-weight: 600; letter-spacing: .1em;
  text-transform: uppercase; color: #b0b8c4; white-space: nowrap;
}
.nav-links {
  display: flex; gap: 28px; align-items: center;
}
.nav-links a {
  font-size: 13px; color: #555; font-weight: 500;
  text-decoration: none; transition: color .15s; white-space: nowrap;
}
.nav-links a:hover { color: #00A0E3; }
.nav-tr {
  border: 1px solid rgba(0,160,227,.3); color: #00A0E3 !important;
  padding: 6px 16px; border-radius: 6px; font-size: 12px !important; font-weight: 700 !important;
}
.nav-ct {
  background: #0a0a14 !important; color: #fff !important;
  padding: 10px 22px; border-radius: 8px;
  font-weight: 700 !important; font-size: 13px !important;
}
.nav-ct:hover { opacity: .85; }

/* ── Przycisk logowania ── */
.nav-login {
  display: flex !important; align-items: center; gap: 7px;
  background: linear-gradient(135deg, #00A0E3, #0077b6) !important;
  color: #fff !important;
  padding: 10px 20px; border-radius: 8px;
  font-weight: 700 !important; font-size: 13px !important;
  box-shadow: 0 2px 12px rgba(0,160,227,.35);
  transition: box-shadow .2s, opacity .2s !important;
}
.nav-login:hover {
  color: #fff !important;
  opacity: .9;
  box-shadow: 0 4px 20px rgba(0,160,227,.5);
}

/* ── Przełącznik języka ── */
.lang-switcher {
  display: flex; align-items: center; gap: 4px;
  border: 1px solid #e8e8e8; border-radius: 8px;
  overflow: hidden; flex-shrink: 0;
}
.lang-btn {
  font-size: 18px !important;
  padding: 4px 8px !important;
  line-height: 1; background: transparent;
  transition: background .15s, opacity .15s !important;
  opacity: .55;
}
.lang-btn:hover { background: #f5f5f5; opacity: 1; }
.lang-active { background: #00A0E3 !important; opacity: 1 !important; border-radius: 6px; }
.lang-active:hover { background: #0091cc !important; }

.nav-burger {
  display: none; flex-direction: column; gap: 5px;
  background: none; border: none; cursor: pointer; padding: 6px; flex-shrink: 0;
}
.nav-burger span { display: block; width: 22px; height: 2px; background: #0a0a14; border-radius: 2px; }

@media (max-width: 960px) {
  .nav { padding: 0 5%; }
  .nav-subtitle { display: none; }
  .nav-divider { display: none; }
  .nav-burger { display: flex; }
  .nav-links {
    display: none; position: absolute; top: 72px; left: 0; right: 0;
    background: #fff; border-bottom: 1px solid #f0f0f0;
    flex-direction: column; align-items: flex-start;
    padding: 20px 5%; gap: 18px;
    box-shadow: 0 8px 24px rgba(0,0,0,.08);
  }
  .nav-links.open { display: flex; }
  .nav-links a { font-size: 15px; width: 100%; }
  .nav-login { justify-content: center; }
  .lang-switcher { align-self: flex-start; }
}
@media (max-width: 480px) {
  .nav-links a { font-size: 14px; }
  .lang-switcher { align-self: center; width: 100%; justify-content: center; }
}
</style>
