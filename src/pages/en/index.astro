---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';

const postFiles = await Astro.glob('../../content/posts/*.md');
const posts = postFiles
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime())
  .slice(0, 3);
---
<Base
  lang="en"
  title="LNG Best Partner Serwis — Cryogenic Tanker Service"
  description="Specialist cryogenic tanker and heavy vehicle service. Laser methane detection, vacuum pump, helium leak detection, thermography. Karlino, Poland."
>
  <Nav lang="en" />

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="hero-l">
      <div class="hero-tag">
        <span class="hero-tag-dot"></span>
        Northern Poland · Cryogenic Service Coverage PL/EU
      </div>
      <h1>Cryogenic tanker service<br>and <em>heavy vehicles</em></h1>
      <p>Built on over a decade of experience in the LNG industry — cryogenic tanker and heavy vehicle service with the knowledge that comes from daily hands-on contact with cryogenic technology.</p>
      <div class="hero-btns">
        <a href="#uslugi" class="btn-dark">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Explore services
        </a>
        <a href="tel:+48795196740" class="btn-blue">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1l-2.3 2.2z" fill="#fff"/></svg>
          +48 795 196 740
        </a>
      </div>
      <div class="hero-stats">
        <div class="hs"><span class="hs-n">10+</span><span class="hs-l">Years of experience</span></div>
        <div class="hs"><span class="hs-n">A–Z</span><span class="hs-l">Full range</span></div>
        <div class="hs"><span class="hs-n">PL/EU</span><span class="hs-l">Cryogenic services</span></div>
      </div>
    </div>

    <div class="hero-r">
      <div class="hero-img">
        <img src="/images/hero-cysterna.jpg" alt="Cryogenic tanker service — LNG Best Partner Karlino" />
      </div>
      <div class="hero-fade"></div>
      <div class="hero-badge">
        <span class="badge-dot"></span>
        <div>
          <div class="badge-t">Workshop available</div>
          <div class="badge-s">Karlino, West Pomeranian Voivodeship</div>
        </div>
      </div>
    </div>
  </section>

  <!-- STRIP -->
  <div class="strip">
    <div class="strip-track">
      <div class="si"><span class="sd"></span>Laser methane detection</div>
      <div class="si"><span class="sd"></span>Vacuum insulation rebuild</div>
      <div class="si"><span class="sd"></span>Helium leak detection</div>
      <div class="si"><span class="sd"></span>ADR Class 2 / TDT</div>
      <div class="si"><span class="sd"></span>Cryogenic service coverage PL/EU</div>
      <div class="si"><span class="sd"></span>Heavy vehicle service</div>
      <!-- loop copy -->
      <div class="si"><span class="sd"></span>Laser methane detection</div>
      <div class="si"><span class="sd"></span>Vacuum insulation rebuild</div>
      <div class="si"><span class="sd"></span>Helium leak detection</div>
      <div class="si"><span class="sd"></span>ADR Class 2 / TDT</div>
      <div class="si"><span class="sd"></span>Cryogenic service coverage PL/EU</div>
      <div class="si"><span class="sd"></span>Heavy vehicle service</div>
    </div>
  </div>

  <!-- ═══ SERVICES ═══ -->
  <section class="section bg-dark" id="uslugi">
    <div class="sh">
      <span class="stag stag-light">Range of Services</span>
      <h2>Comprehensive service — cryogenic and heavy vehicle</h2>
      <p>We cover the full spectrum of technical needs — from heavy vehicle service, through cryogenic diagnostics, to mobile LNG tanker emergency response.</p>
    </div>
    <div class="ug">
      <div class="uc reveal d1">
        <div class="uc-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="1" y="3" width="15" height="13" rx="2" stroke="#00A0E3" stroke-width="1.5"/><path d="M16 8h4l3 4v5h-7V8z" stroke="#00A0E3" stroke-width="1.5" stroke-linejoin="round"/><circle cx="5.5" cy="18.5" r="2.5" stroke="#00A0E3" stroke-width="1.5"/><circle cx="18.5" cy="18.5" r="2.5" stroke="#00A0E3" stroke-width="1.5"/></svg></div>
        <div class="uc-n">01</div><h3>Heavy vehicle repair</h3><p>Comprehensive maintenance of heavy vehicles with particular focus on Scania, Volvo and Renault. We also service vehicles from all other manufacturers.</p>
      </div>
      <div class="uc reveal d2">
        <div class="uc-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="2" y="7" width="18" height="10" rx="2" stroke="#00A0E3" stroke-width="1.5"/><path d="M20 17h2v-4" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/><circle cx="7" cy="19" r="2" stroke="#00A0E3" stroke-width="1.5"/><circle cx="15" cy="19" r="2" stroke="#00A0E3" stroke-width="1.5"/></svg></div>
        <div class="uc-n">02</div><h3>Trailer and semi-trailer repair</h3><p>Repair of all heavy trailers and semi-trailers operating on systems by brands such as KNORR-BREMSE, WABCO, ZF and HALDEX.</p>
      </div>
      <div class="uc reveal d3">
        <div class="uc-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/><circle cx="12" cy="12" r="3" stroke="#00A0E3" stroke-width="1.5"/></svg></div>
        <div class="uc-n">03</div><h3>Cryogenic semi-trailer service</h3><p>We specialise in the servicing of cryogenic semi-trailers, including diagnostics, repairs and maintenance of trailers used to transport liquefied gases.</p>
      </div>
      <div class="uc reveal d4">
        <div class="uc-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="#00A0E3" stroke-width="1.5"/><circle cx="12" cy="12" r="4" stroke="#00A0E3" stroke-width="1.5"/><path d="M12 3v2M12 19v2M3 12h2M19 12h2" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg></div>
        <div class="uc-n">04</div><h3>Tyre services</h3><p>Tyre services for heavy vehicles, including replacement and repair. Fast, professional work tailored to the needs of the transport industry.</p>
      </div>
      <div class="uc reveal d5">
        <div class="uc-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 2a7 7 0 0 1 7 7c0 5-7 13-7 13S5 14 5 9a7 7 0 0 1 7-7z" stroke="#00A0E3" stroke-width="1.5"/><circle cx="12" cy="9" r="2.5" stroke="#00A0E3" stroke-width="1.5"/></svg></div>
        <div class="uc-n">05</div><h3>Vacuum tank maintenance</h3><p>Maintenance of mobile and stationary vacuum tanks, ensuring continuous technical reliability and safe operation.</p>
      </div>
      <div class="uc reveal d6">
        <div class="uc-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="3" stroke="#00A0E3" stroke-width="1.5"/><ellipse cx="12" cy="12" rx="10" ry="4" stroke="#00A0E3" stroke-width="1.5"/><ellipse cx="12" cy="12" rx="10" ry="4" stroke="#00A0E3" stroke-width="1.5" transform="rotate(60 12 12)"/><ellipse cx="12" cy="12" rx="10" ry="4" stroke="#00A0E3" stroke-width="1.5" transform="rotate(120 12 12)"/></svg></div>
        <div class="uc-n">06</div><h3>Helium leak detection</h3><p>Precise detection of even the smallest leaks in installations and tanks. Modern testing methods guarantee high effectiveness and safety.</p>
      </div>
      <div class="uc reveal d7">
        <div class="uc-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="5" y="2" width="14" height="20" rx="2" stroke="#00A0E3" stroke-width="1.5"/><path d="M9 7h6M9 11h6M9 15h4" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/><path d="M15 1v4M9 1v4" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg></div>
        <div class="uc-n">07</div><h3>TDT inspection preparation</h3><p>Comprehensive preparation of vehicles and equipment for TDT technical inspections, including a technical review, necessary repairs and compliance verification.</p>
      </div>
      <div class="uc reveal d8">
        <div class="uc-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="#00A0E3" stroke-width="1.5" stroke-linejoin="round"/></svg></div>
        <div class="uc-n">08</div><h3>Mobile LNG tanker emergency service</h3><p>Mobile LNG tanker emergency response — fast, professional on-site assistance at the point of breakdown. Efficient diagnostics, repairs and minimisation of downtime.</p>
      </div>
      <div class="uc reveal d9">
        <div class="uc-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z" stroke="#00A0E3" stroke-width="1.5" stroke-linejoin="round"/></svg></div>
        <div class="uc-n">09</div><h3>Thermographic measurements</h3><p>Thermographic measurements enabling assessment of the technical condition of installations and equipment. Modern apparatus, reliable results and detailed documentation.</p>
      </div>
    </div>
  </section>

  <!-- ═══ TECHNOLOGY ═══ -->
  <section class="split-tech bg-white" id="technologia">
    <div class="tech-img">
      <img src="/images/tech-pompa.jpg" alt="Vacuum pump — cryogenic service" />
    </div>
    <div class="tech-fade"></div>
    <div class="tech-content">
      <span class="stag">Technology &amp; Diagnostics</span>
      <h2>Advanced diagnostic equipment</h2>
      <p>We invest in industrial-grade technology. Every job is carried out with precision unavailable at a standard workshop.</p>
      <div class="tis">
        <div class="ti">
          <div class="ti-ic"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg></div>
          <div><div class="ti-t">Laser methane detector</div><div class="ti-d">Continuous atmospheric monitoring — real-time protection of property and personnel.</div></div>
        </div>
        <div class="ti">
          <div class="ti-ic"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="3" stroke="#00A0E3" stroke-width="1.5"/><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg></div>
          <div><div class="ti-t">Helium leak detection</div><div class="ti-d">Leak identification impossible by conventional methods.</div></div>
        </div>
        <div class="ti">
          <div class="ti-ic"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M2 12h1M21 12h1M12 2v1M12 21v1M4.93 4.93l.7.7M18.37 18.37l.7.7M4.93 19.07l.7-.7M18.37 5.63l.7-.7" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/><circle cx="12" cy="12" r="4" stroke="#00A0E3" stroke-width="1.5"/></svg></div>
          <div><div class="ti-t">Thermal imaging camera</div><div class="ti-d">Detects cold spots penetrating the outer shell — wherever vacuum insulation loses effectiveness, the camera will show it.</div></div>
        </div>
        <div class="ti">
          <div class="ti-ic"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><ellipse cx="12" cy="12" rx="10" ry="10" stroke="#00A0E3" stroke-width="1.5"/><path d="M12 8v4l3 3" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg></div>
          <div><div class="ti-t">Vacuum pump</div><div class="ti-d">Regeneration of vacuum insulation chambers in cryogenic semi-trailers and stationary tanks to factory specifications.</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ SAFETY ═══ -->
  <section class="section bg-gray">
    <div class="safety-inner">
      <div class="safety-text">
        <span class="stag">Safety</span>
        <h2>Industrial-grade safety standards</h2>
        <p>In a cryogenic environment there is no room for compromise. We use laser methane detection — continuous monitoring of the working atmosphere protects both the property entrusted to us and our personnel.</p>
        <div class="sclaim">
          <div class="sc-ck">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          Laser methane detection in the workshop environment
        </div>
      </div>
      <div class="scards">
        <div class="scard">
          <div class="scard-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="#00A0E3" stroke-width="1.5" stroke-linejoin="round"/></svg></div>
          <div class="scard-t">Laser methane detector</div>
          <p class="scard-d">Atmospheric monitoring — threat detection before it occurs.</p>
        </div>
        <div class="scard">
          <div class="scard-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><rect x="3" y="11" width="18" height="11" rx="2" stroke="#00A0E3" stroke-width="1.5"/><path d="M7 11V7a5 5 0 0 1 10 0v4" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg></div>
          <div class="scard-t">Client property protection</div>
          <p class="scard-d">Your tanker in a fully controlled work environment.</p>
        </div>
        <div class="scard">
          <div class="scard-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="#00A0E3" stroke-width="1.5"/></svg></div>
          <div class="scard-t">Personnel safety</div>
          <p class="scard-d">Certified procedures and industrial-grade equipment.</p>
        </div>
        <div class="scard">
          <div class="scard-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M9 11l3 3L22 4" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg></div>
          <div class="scard-t">TDT Class 2 authorisation</div>
          <p class="scard-d">Authorisation to prepare Class 2 cryogenic tankers for technical inspections.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VEHICLES ═══ -->
  <section class="split-vehicles bg-white">
    <div class="vehicles-img">
      <img src="/images/vehicles-serwis.jpg" alt="Semi-trailer tractor service — Scania Volvo Renault Karlino" />
    </div>
    <div class="vehicles-fade"></div>
    <div class="vehicles-content">
      <span class="stag">Heavy Vehicle Service</span>
      <h2>Semi-trailer tractors — our second speciality</h2>
      <p>Full-scope technical maintenance of heavy vehicles and semi-trailers. We specialise in Scandinavian brands — but we service every make without exception.</p>
      <div class="brands">
        <span class="bm">Scania</span><span class="bm">Volvo</span><span class="bm">Renault</span>
        <span class="bs">MAN</span><span class="bs">DAF</span><span class="bs">Mercedes</span><span class="bs">+ others</span>
      </div>
      <p class="vnote">Fleet service agreements · Priority response time · Dedicated technical contact</p>
    </div>
  </section>

  <!-- ═══ GALLERY ═══ -->
  <section class="section bg-gray" id="galeria">

    <h2 class="gal-title">Gallery</h2>
    <p class="gal-sub">Workshop and project photos</p>
    <div class="gg">
      <div class="gi big"><img src="/images/galeria-1.jpg" alt="Cryogenic service project" /></div>
      <div class="gi"><img src="/images/galeria-2.jpg" alt="LNG Best Partner workshop" /></div>
      <div class="gi"><img src="/images/galeria-3.jpg" alt="Tanker service" /></div>
      <div class="gi"><img src="/images/galeria-4.jpg" alt="Vacuum pump" /></div>
      <div class="gi"><img src="/images/galeria-5.jpg" alt="Vehicle service" /></div>
    </div>
  </section>

  <!-- ═══ NEWS ═══ -->
  <section class="section bg-white">
    <div class="news-hdr">
      <div>
        <span class="stag">News</span>
        <h2 class="news-title">From the workshop floor</h2>
      </div>
      <a href="/en/news" class="news-more">
        All posts
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="#00A0E3" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
    <div class="ng">
      {posts.map((post, i) => (
        <a href={post.url} class={`nc ${i === 0 ? 'big' : ''}`}>
          <div class="nc-img">
            {post.frontmatter.image
              ? <img src={post.frontmatter.image} alt={post.frontmatter.title} loading="lazy" />
              : <div class="nc-ph"></div>
            }
            <span class="nc-tag">{post.frontmatter.tag ?? 'News'}</span>
          </div>
          <div class="nc-body">
            <div class="nc-date">{new Date(post.frontmatter.date).toLocaleDateString('en-GB', { year:'numeric', month:'long' })}</div>
            <h4>{post.frontmatter.title}</h4>
            <p>{post.frontmatter.excerpt}</p>
          </div>
        </a>
      ))}
      {posts.length === 0 && (
        <p class="empty">The first posts will appear soon.</p>
      )}
    </div>
  </section>

  <!-- ═══ CONTACT ═══ -->
  <section class="section bg-dark" id="kontakt">
    <div class="contact-inner">
      <div class="ci">
        <span class="stag stag-light">Contact</span>
        <h2>Let's talk about your tanker or fleet</h2>
        <p>Quote, service agreement, or urgent breakdown — we respond promptly and to the point.</p>
        <div class="ci-groups">
          <div class="ci-group">
            <div class="ci-group-h">Service</div>
            <div class="cd">
              <div class="cd-ic"><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1l-2.3 2.2z" fill="#00A0E3"/></svg></div>
              <div><div class="cd-l">Phone</div><a href="tel:+48795196740" class="cd-v">+48 795 196 740</a></div>
            </div>
            <div class="cd" style="margin-bottom:0">
              <div class="cd-ic"><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="#00A0E3" stroke-width="1.5"/><polyline points="22,6 12,13 2,6" stroke="#00A0E3" stroke-width="1.5"/></svg></div>
              <div><div class="cd-l">E-mail</div><a href="mailto:serwis@lngbestpartner.pl" class="cd-v">Serwis@lngbestpartner.pl</a></div>
            </div>
          </div>
          <div class="ci-group">
            <div class="ci-group-h">Management</div>
            <div class="cd">
              <div class="cd-ic"><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1l-2.3 2.2z" fill="#00A0E3"/></svg></div>
              <div><div class="cd-l">Phone</div><a href="tel:+48502153705" class="cd-v">+48 502 153 705</a></div>
            </div>
            <div class="cd">
              <div class="cd-ic"><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1l-2.3 2.2z" fill="#00A0E3"/></svg></div>
              <div><div class="cd-l">Phone</div><a href="tel:+48668230812" class="cd-v">+48 668 230 812</a></div>
            </div>
            <div class="cd" style="margin-bottom:0">
              <div class="cd-ic"><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="#00A0E3" stroke-width="1.5"/><polyline points="22,6 12,13 2,6" stroke="#00A0E3" stroke-width="1.5"/></svg></div>
              <div><div class="cd-l">E-mail</div><a href="mailto:biuro@lngbestpartner.pl" class="cd-v">biuro@lngbestpartner.pl</a></div>
            </div>
          </div>
        </div>
        <div class="ci-meta">
