---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';

export async function getStaticPaths() {
  const posts = await Astro.glob('../../content/posts/pl/*.md');
  return posts.map(post => {
    const slug = post.file.split('/').pop().replace('.md', '');
    return { params: { slug }, props: { post } };
  });
}

const { post } = Astro.props;
const { Content, frontmatter } = post;
const formattedDate = new Date(frontmatter.date).toLocaleDateString('pl-PL', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base title={`${frontmatter.title} — LNG Best Partner Serwis`} description={frontmatter.excerpt}>
  <Nav />
  <article class="post">
    {frontmatter.image && (
      <div class="post-hero">
        <img src={frontmatter.image} alt={frontmatter.title} />
      </div>
    )}
    <div class="post-content">
      <div class="post-meta">
        <span class="post-tag">{frontmatter.tag}</span>
        <span class="post-date">{formattedDate}</span>
      </div>
      <h1>{frontmatter.title}</h1>
      <div class="post-body">
        <Content />
      </div>
      <a href="/aktualnosci" class="back">← Powrót do aktualności</a>
    </div>
  </article>
  <footer class="footer">
    <div class="fc">© 2026 LNG Best Partner Sp. z o.o. · NIP 6722081703 · Krzywopłoty 2A, 78-230 Karlino</div>
    <div class="fl">
      <a href="/">Strona główna</a>
      <a href="https://transport-lng.pl" target="_blank" rel="noopener" class="fl-tr">↗ transport-lng.pl</a>
    </div>
  </footer>
</Base>

<style>
.post { max-width: 820px; margin: 0 auto; padding-bottom: 64px; }
.post-hero { width: 100%; max-height: 460px; overflow: hidden; }
.post-hero img { width: 100%; height: 100%; object-fit: cover; display: block; }
.post-content { padding: 48px 6%; }
.post-meta { display: flex; align-items: center; gap: 14px; margin-bottom: 18px; }
.post-tag { background: #0a0a14; color: #fff; font-size: 9px; font-weight: 700; padding: 4px 12px; border-radius: 20px; text-transform: uppercase; letter-spacing: .06em; }
.post-date { font-size: 12px; color: #aaa; }
h1 { font-size: clamp(22px, 3vw, 36px); font-weight: 900; color: #0a0a14; line-height: 1.25; letter-spacing: -.025em; margin-bottom: 32px; }
.post-body { font-size: 15px; color: #333; line-height: 1.8; }
.post-body :global(h2) { font-size: 18px; font-weight: 800; color: #0a0a14; margin: 36px 0 12px; }
.post-body :global(p) { margin-bottom: 18px; }
.post-body :global(ul) { padding-left: 20px; margin-bottom: 18px; }
.post-body :global(li) { margin-bottom: 6px; }
.back { display: inline-block; margin-top: 40px; font-size: 13px; font-weight: 700; color: #00A0E3; text-decoration: none; }
.footer { background: #060a10; padding: 22px 6%; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; }
.fc { font-size: 11px; color: rgba(255,255,255,.2); }
.fl { display: flex; gap: 18px; align-items: center; }
.fl a { font-size: 11px; color: rgba(255,255,255,.2); text-decoration: none; }
.fl-tr { background: rgba(0,160,227,.1); border: 1px solid rgba(0,160,227,.18); color: #00A0E3 !important; padding: 6px 14px; border-radius: 6px; font-weight: 700; font-size: 12px !important; }
@media (max-width: 600px) { .post-content { padding: 32px 5%; } }
</style>
