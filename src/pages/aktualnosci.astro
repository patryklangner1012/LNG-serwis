---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';

const postFiles = await Astro.glob('../content/posts/*.md');
const posts = postFiles.sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());
---
<Base title="Aktualności — LNG Best Partner Serwis">
  <Nav />
  <section class="page-hero">
    <div class="eyebrow"><div class="eyebrow-line"></div><span class="eyebrow-text">Blog / Aktualności</span></div>
    <h1>Z życia warsztatu</h1>
    <p>Realizacje, nowe usługi, interwencje serwisowe i aktualności z branży kriogenicznej.</p>
  </section>
  <section class="posts-grid">
    {posts.map(post => (
      <a href={post.url} class="post-card">
        <div class="post-img">
          {post.frontmatter.image
            ? <img src={post.frontmatter.image} alt={post.frontmatter.title} loading="lazy" />
            : <div class="post-placeholder"></div>
          }
          <span class="post-tag">{post.frontmatter.tag ?? 'Aktualność'}</span>
        </div>
        <div class="post-body">
          <div class="post-date">{new Date(post.frontmatter.date).toLocaleDateString('pl-PL', { year:'numeric', month:'long', day:'numeric' })}</div>
          <h2>{post.frontmatter.title}</h2>
          <p>{post.frontmatter.excerpt}</p>
          <span class="post-read">Czytaj więcej →</span>
        </div>
      </a>
    ))}
    {posts.length === 0 && (
      <p class="empty">Pierwsze wpisy pojawią się wkrótce.</p>
    )}
  </section>
  <footer class="footer">
    <div class="footer-copy">© 2025 LNG Best Partner Sp. z o.o. · NIP 6722081703 · Krzywopłoty 2A, 78-230 Karlino</div>
    <div class="footer-links">
      <a href="/">Strona główna</a>
      <a href="https://transport-lng.pl" target="_blank" class="footer-transport">↗ transport-lng.pl</a>
    </div>
  </footer>
</Base>

<style>
.page-hero {
  padding: 72px 48px 48px;
  background: #f7f9fc;
  border-bottom: 1px solid #e8eef4;
}
.page-hero h1 { font-size: 36px; font-weight: 800; color: #0f0f1a; margin-bottom: 10px; font-family: var(--font-display); }
.page-hero p { font-size: 15px; color: #5a6a7a; max-width: 480px; }
.posts-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  padding: 56px 48px;
  background: #fff;
  min-height: 400px;
}
.post-card {
  border: 1px solid #ebebeb; border-radius: 12px; overflow: hidden;
  display: flex; flex-direction: column; text-decoration: none;
  transition: box-shadow .2s;
}
.post-card:hover { box-shadow: 0 6px 24px rgba(0,0,0,.08); }
.post-img { position: relative; height: 180px; background: #d0dce8; overflow: hidden; }
.post-img img { width: 100%; height: 100%; object-fit: cover; }
.post-placeholder { width: 100%; height: 100%; background: linear-gradient(135deg,#c8d8e8,#a8bdd0); }
.post-tag {
  position: absolute; top: 10px; left: 10px;
  background: #fff; color: #00A0E3; font-size: 10px; font-weight: 700;
  padding: 3px 9px; border-radius: 20px; text-transform: uppercase; letter-spacing: .06em;
}
.post-body { padding: 20px; flex: 1; display: flex; flex-direction: column; }
.post-date { font-size: 11px; color: #ccc; margin-bottom: 8px; }
.post-body h2 { font-size: 15px; font-weight: 700; color: #0f0f1a; line-height: 1.4; margin-bottom: 8px; font-family: var(--font-display); }
.post-body p { font-size: 13px; color: #888; line-height: 1.6; flex: 1; }
.post-read { font-size: 12px; color: #00A0E3; margin-top: 14px; font-weight: 600; }
.empty { color: #9aaab8; font-size: 14px; grid-column: 1/-1; }
.footer {
  background: #080d12; padding: 22px 48px;
  display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px;
}
.footer-copy { font-size: 11px; color: rgba(255,255,255,.25); }
.footer-links { display: flex; gap: 18px; align-items: center; }
.footer-links a { font-size: 11px; color: rgba(255,255,255,.25); }
.footer-transport {
  background: rgba(0,160,227,.1); border: 1px solid rgba(0,160,227,.2);
  color: #00A0E3 !important; padding: 6px 14px; border-radius: 6px; font-weight: 500; font-size: 12px !important;
}
@media (max-width: 900px) {
  .posts-grid { grid-template-columns: 1fr; padding: 32px 24px; }
  .page-hero { padding: 48px 24px 32px; }
}
</style>
