---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';

const postFiles = await Astro.glob('../content/posts/*.md');
const posts = postFiles.sort((a, b) =>
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);
---
<Base title="Aktualności — LNG Best Partner Serwis">
  <Nav />
  <section class="page-hero">
    <span class="stag">Blog / Aktualności</span>
    <h1>Z życia warsztatu</h1>
    <p>Realizacje, nowe usługi, interwencje serwisowe i aktualności z branży kriogenicznej.</p>
  </section>
  <section class="posts">
    <div class="posts-grid">
      {posts.map(post => (
        <a href={post.url} class="pc">
          <div class="pc-img">
            {post.frontmatter.image
              ? <img src={post.frontmatter.image} alt={post.frontmatter.title} loading="lazy" />
              : <div class="pc-ph"></div>
            }
            <span class="pc-tag">{post.frontmatter.tag ?? 'Aktualność'}</span>
          </div>
          <div class="pc-body">
            <div class="pc-date">{new Date(post.frontmatter.date).toLocaleDateString('pl-PL', { year:'numeric', month:'long', day:'numeric' })}</div>
            <h2>{post.frontmatter.title}</h2>
            <p>{post.frontmatter.excerpt}</p>
            <span class="pc-read">Czytaj więcej →</span>
          </div>
        </a>
      ))}
      {posts.length === 0 && <p class="empty">Pierwsze wpisy pojawią się wkrótce.</p>}
    </div>
  </section>
  <footer class="footer">
    <div class="fc">© 2025 LNG Best Partner Sp. z o.o. · NIP 6722081703 · Krzywopłoty 2A, 78-230 Karlino</div>
    <div class="fl">
      <a href="/">Strona główna</a>
      <a href="https://transport-lng.pl" target="_blank" class="fl-tr">↗ transport-lng.pl</a>
    </div>
  </footer>
</Base>

<style>
.page-hero { padding: 72px 6% 48px; background: #f7f9fc; border-bottom: 1px solid #e8eef4; }
.page-hero h1 { font-size: clamp(28px, 3vw, 44px); font-weight: 900; color: #0a0a14; margin-bottom: 10px; letter-spacing: -.025em; }
.page-hero p { font-size: 15px; color: #6a7a8a; max-width: 480px; line-height: 1.75; }
.posts { padding: 56px 6%; background: #fff; min-height: 400px; }
.posts-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; }
.pc { border: 1px solid #ebebeb; border-radius: 14px; overflow: hidden; display: flex; flex-direction: column; text-decoration: none; transition: box-shadow .2s, transform .2s; }
.pc:hover { box-shadow: 0 8px 28px rgba(0,0,0,.08); transform: translateY(-3px); }
.pc-img { position: relative; height: 200px; background: #c8d8e8; overflow: hidden; }
.pc-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.pc-ph { width: 100%; height: 100%; background: linear-gradient(135deg,#c8d8e8,#a8bdd0); }
.pc-tag { position: absolute; top: 10px; left: 10px; background: #0a0a14; color: #fff; font-size: 9px; font-weight: 700; padding: 4px 10px; border-radius: 20px; text-transform: uppercase; letter-spacing: .06em; }
.pc-body { padding: 22px; flex: 1; display: flex; flex-direction: column; }
.pc-date { font-size: 11px; color: #ccc; margin-bottom: 8px; }
.pc-body h2 { font-size: 16px; font-weight: 700; color: #0a0a14; line-height: 1.4; margin-bottom: 8px; }
.pc-body p { font-size: 13px; color: #888; line-height: 1.6; flex: 1; }
.pc-read { font-size: 12px; color: #00A0E3; margin-top: 14px; font-weight: 700; }
.empty { color: #9aaab8; font-size: 14px; grid-column: 1/-1; }
.footer { background: #060a10; padding: 22px 6%; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; }
.fc { font-size: 11px; color: rgba(255,255,255,.2); }
.fl { display: flex; gap: 18px; align-items: center; }
.fl a { font-size: 11px; color: rgba(255,255,255,.2); text-decoration: none; }
.fl-tr { background: rgba(0,160,227,.1); border: 1px solid rgba(0,160,227,.18); color: #00A0E3 !important; padding: 6px 14px; border-radius: 6px; font-weight: 700; font-size: 12px !important; }
@media (max-width: 900px) { .posts-grid { grid-template-columns: 1fr 1fr; } }
@media (max-width: 600px) { .posts-grid { grid-template-columns: 1fr; padding: 32px 5%; } .page-hero { padding: 48px 5% 32px; } }
</style>
