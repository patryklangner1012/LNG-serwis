---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';

// Pobierz posty z folderu content
const postFiles = await Astro.glob('../content/posts/*.md');
const posts = postFiles
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime())
  .slice(0, 3);
---
<Base>
  <Nav />

  <!-- ═══════════════════════════════════════
       HERO — pochyłe zdjęcie prawa strona
  ═══════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-photo">
      <!-- WSTAW ZDJĘCIE: cysterna kriogeniczna / warsztat. Rekomendowany format: 1400×900px -->
      <img src="/images/hero-cysterna.jpg" alt="Serwis cystern kriogenicznych LNG Best Partner" loading="eager" />
    </div>
    <div class="hero-fade"></div>
    <div class="hero-content">
      <div class="eyebrow">
        <div class="eyebrow-line"></div>
        <span class="eyebrow-text">Północna Polska · Obsługa Europy</span>
      </div>
      <h1>Specjalistyczny serwis<br>cystern <em>kriogenicznych</em><br>i technologii LNG</h1>
      <p class="hero-sub">Ponad dekada precyzji technicznej w obsłudze pojazdów i zbiorników kriogenicznych. Laserowa detekcja metanu, helowa identyfikacja nieszczelności, termowizja. Jeden partner. Pełna odpowiedzialność.</p>
      <div class="hero-actions">
        <a href="/#uslugi" class="btn-dark">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Poznaj nasze usługi
        </a>
        <a href="tel:795196740" class="btn-blue">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1l-2.3 2.2z" fill="#fff"/></svg>
          795 196 740
        </a>
      </div>
      <div class="hero-stats">
        <div class="stat"><span class="stat-n">10+</span><span class="stat-l">Lat doświadczenia</span></div>
        <div class="stat"><span class="stat-n">A–Z</span><span class="stat-l">Pełen zakres obsługi</span></div>
        <div class="stat"><span class="stat-n">PL/EU</span><span class="stat-l">Zasięg mobilny</span></div>
      </div>
    </div>
    <div class="hero-badge">
      <span class="badge-dot"></span>
      <div>
        <div class="badge-title">Warsztat dostępny</div>
        <div class="badge-sub">Karlino, woj. zachodniopomorskie</div>
      </div>
    </div>
  </section>

  <!-- STRIP -->
  <div class="strip">
    <div class="strip-item"><div class="strip-dot"></div>Laserowa detekcja metanu — pierwsi w Polsce</div>
    <div class="strip-item"><div class="strip-dot"></div>Odbudowa izolacji próżniowej</div>
    <div class="strip-item"><div class="strip-dot"></div>Helowa detekcja nieszczelności</div>
    <div class="strip-item"><div class="strip-dot"></div>ADR klasa 2</div>
    <div class="strip-item"><div class="strip-dot"></div>Serwis mobilny EU</div>
  </div>

  <!-- ═══════════════════════════════════════
       3 FILARY
  ═══════════════════════════════════════ -->
  <section class="pillars" id="uslugi">
    <div class="pillars-header">
      <div class="eyebrow"><div class="eyebrow-line"></div><span class="eyebrow-text">Czym się wyróżniamy</span></div>
      <h2 class="section-title">Standardy, które definiują branżę</h2>
      <p class="section-sub">Łączymy wieloletnie doświadczenie z technologiami diagnostycznymi niedostępnymi w żadnym innym warsztacie kriogenicznym w Polsce.</p>
    </div>
    <div class="pillars-grid">
      <div class="pillar">
        <div class="pillar-num">01</div>
        <h3>Pełna obsługa — od diagnostyki po regenerację próżni</h3>
        <p>Od drobnych interwencji serwisowych po kompleksową odbudowę izolacji próżniowej — serca każdej cysterny kriogenicznej. Jeden serwis, pełna odpowiedzialność techniczna.</p>
      </div>
      <div class="pillar">
        <div class="pillar-num">02</div>
        <h3>Technologie diagnostyczne niedostępne w regionie</h3>
        <p>Laserowy detektor metanu, helowa identyfikacja nieszczelności, kamera termowizyjna i nowoczesna stacja próżniowa — precyzja diagnostyki na poziomie zakładu produkcyjnego.</p>
      </div>
      <div class="pillar">
        <div class="pillar-num">03</div>
        <h3>Bezpieczeństwo powierzonego mienia i personelu</h3>
        <p>Jako pierwsi w Polsce wdrożyliśmy laserową detekcję metanu w środowisku warsztatowym. Praca przy mediach kriogenicznych wymaga najwyższych standardów — i tymi standardami się kierujemy.</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       TECHNOLOGIA — foto pochyłe z lewej
  ═══════════════════════════════════════ -->
  <section class="tech" id="technologia">
    <div class="tech-photo">
      <!-- WSTAW ZDJĘCIE: sprzęt diagnostyczny / stacja próżniowa / laserowy detektor. Format: 1200×900px -->
      <img src="/images/tech-sprzet.jpg" alt="Nowoczesny sprzęt diagnostyczny" loading="lazy" />
    </div>
    <div class="tech-photo-fade"></div>
    <div class="tech-content">
      <div class="eyebrow"><div class="eyebrow-line"></div><span class="eyebrow-text">Technologia i diagnostyka</span></div>
      <h2 class="section-title">Sprzęt, który zmienia jakość diagnozy</h2>
      <p class="section-sub" style="margin-bottom:28px">Każde zlecenie realizujemy z użyciem precyzyjnych narzędzi diagnostycznych, które pozwalają identyfikować problemy zanim staną się kosztownymi awariami.</p>
      <div class="tech-items">
        <div class="tech-item">
          <div class="ti-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
          <div>
            <div class="ti-title">Laserowa detekcja metanu</div>
            <div class="ti-desc">Pierwsi w Polsce w środowisku warsztatowym. Ciągły monitoring w czasie rzeczywistym — bezpieczeństwo na poziomie przemysłowym.</div>
          </div>
        </div>
        <div class="tech-item">
          <div class="ti-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="3" stroke="#00A0E3" stroke-width="1.5"/><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
          <div>
            <div class="ti-title">Helowa detekcja nieszczelności</div>
            <div class="ti-desc">Precyzyjna identyfikacja przecieków w układach próżniowych — niemożliwa do osiągnięcia metodami konwencjonalnymi.</div>
          </div>
        </div>
        <div class="tech-item">
          <div class="ti-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M2 12h1M21 12h1M12 2v1M12 21v1M4.93 4.93l.7.7M18.37 18.37l.7.7M4.93 19.07l.7-.7M18.37 5.63l.7-.7" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/><circle cx="12" cy="12" r="4" stroke="#00A0E3" stroke-width="1.5"/></svg>
          </div>
          <div>
            <div class="ti-title">Pomiary termowizyjne</div>
            <div class="ti-desc">Ocena stanu izolacji i układów elektrycznych bez demontażu. Szybka diagnostyka, precyzyjny wynik.</div>
          </div>
        </div>
        <div class="tech-item">
          <div class="ti-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><ellipse cx="12" cy="12" rx="10" ry="10" stroke="#00A0E3" stroke-width="1.5"/><path d="M12 8v4l3 3" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
          <div>
            <div class="ti-title">Stacja odbudowy izolacji próżniowej</div>
            <div class="ti-desc">Nowoczesna stacja próżniowa do pełnej regeneracji naczep kriogenicznych i zbiorników stacjonarnych LNG.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       BEZPIECZEŃSTWO
  ═══════════════════════════════════════ -->
  <section class="safety">
    <div class="safety-text">
      <div class="eyebrow eyebrow--light"><div class="eyebrow-line"></div><span class="eyebrow-text">Bezpieczeństwo</span></div>
      <h2>Pierwsi w Polsce z laserową detekcją metanu w warsztacie</h2>
      <p>W środowisku kriogenicznym nie ma miejsca na kompromisy. Wdrożyliśmy standardy ochrony, które stawiają nas w awangardzie branży — i które chronią zarówno powierzone nam mienie, jak i nasz personel.</p>
      <div class="safety-claim">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#00A0E3" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Pierwszy warsztat kriogeniczny w Polsce z laserową detekcją metanu
      </div>
    </div>
    <div class="safety-cards">
      <div class="scard">
        <div class="scard-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="#00A0E3" stroke-width="1.5" stroke-linejoin="round"/></svg></div>
        <div class="scard-title">Laserowy detektor metanu</div>
        <p class="scard-desc">Monitoring atmosfery w czasie rzeczywistym. Wykrycie śladowych stężeń gazu zanim stanie się zagrożeniem.</p>
      </div>
      <div class="scard">
        <div class="scard-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><rect x="3" y="11" width="18" height="11" rx="2" stroke="#00A0E3" stroke-width="1.5"/><path d="M7 11V7a5 5 0 0 1 10 0v4" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg></div>
        <div class="scard-title">Ochrona powierzonego mienia</div>
        <p class="scard-desc">Twoja cysterna pod pełną kontrolą środowiska pracy. Zero kompromisów w zakresie bezpieczeństwa.</p>
      </div>
      <div class="scard">
        <div class="scard-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="#00A0E3" stroke-width="1.5"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg></div>
        <div class="scard-title">Bezpieczeństwo personelu</div>
        <p class="scard-desc">Certyfikowane procedury i sprzęt ochronny klasy przemysłowej. Nasz zespół pracuje w najwyższych standardach.</p>
      </div>
      <div class="scard">
        <div class="scard-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M9 11l3 3L22 4" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg></div>
        <div class="scard-title">Uprawnienia ADR klasa 2</div>
        <p class="scard-desc">Przygotowanie do badań UDT. Wszystkie prace zgodnie z przepisami transportu materiałów niebezpiecznych.</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       SERWIS POJAZDÓW — foto pochyłe z prawej
  ═══════════════════════════════════════ -->
  <section class="vehicles">
    <div class="vehicles-content">
      <div class="eyebrow"><div class="eyebrow-line"></div><span class="eyebrow-text">Serwis pojazdów ciężarowych</span></div>
      <h2 class="section-title">Ciągniki siodłowe — nasza druga specjalność</h2>
      <p style="font-size:14px;color:var(--text-muted);line-height:1.75;margin-bottom:20px">Równolegle z serwisem kriogenicznym prowadzimy pełnozakresową obsługę techniczną pojazdów ciężarowych. Specjalizujemy się w markach skandynawskich, jednak żaden pojazd nie jest nam obcy.</p>
      <div class="brands">
        <span class="brand main">Scania</span>
        <span class="brand main">Volvo</span>
        <span class="brand main">Renault</span>
        <span class="brand">MAN</span>
        <span class="brand">DAF</span>
        <span class="brand">Mercedes</span>
        <span class="brand">+ inne marki</span>
      </div>
      <p style="font-size:13px;color:var(--text-light);line-height:1.75">Obsługujemy zarówno jednostkowe zlecenia jak i całe floty. Umowy serwisowe z priorytetowym czasem reakcji i dedykowanym kontaktem technicznym.</p>
    </div>
    <div class="vehicles-photo">
      <!-- WSTAW ZDJĘCIE: ciągnik siodłowy w warsztacie / naprawa. Format: 1200×900px -->
      <img src="/images/vehicles-serwis.jpg" alt="Serwis ciągników siodłowych Scania Volvo Renault" loading="lazy" />
    </div>
    <div class="vehicles-fade"></div>
  </section>

  <!-- ═══════════════════════════════════════
       AKTUALNOŚCI
  ═══════════════════════════════════════ -->
  <section class="news">
    <div class="news-header">
      <div>
        <div class="eyebrow"><div class="eyebrow-line"></div><span class="eyebrow-text">Aktualności</span></div>
        <h2 class="section-title">Z życia warsztatu</h2>
      </div>
      <a href="/aktualnosci" class="news-more">Wszystkie wpisy →</a>
    </div>
    <div class="news-grid">
      {posts.map((post, i) => (
        <a href={post.url} class={`ncard ${i === 0 ? 'ncard--big' : ''}`}>
          <div class="ncard-img">
            {post.frontmatter.image
              ? <img src={post.frontmatter.image} alt={post.frontmatter.title} loading="lazy" />
              : <div class="ncard-placeholder"></div>
            }
            <span class="ntag">{post.frontmatter.tag ?? 'Aktualność'}</span>
          </div>
          <div class="ncard-body">
            <div class="ndate">{new Date(post.frontmatter.date).toLocaleDateString('pl-PL', { year:'numeric', month:'long' })}</div>
            <h4>{post.frontmatter.title}</h4>
            <p>{post.frontmatter.excerpt}</p>
          </div>
        </a>
      ))}
      {posts.length === 0 && (
        <p style="color:var(--text-light);font-size:14px;grid-column:1/-1">Pierwsze wpisy pojawią się wkrótce.</p>
      )}
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       KONTAKT
  ═══════════════════════════════════════ -->
  <section class="contact" id="kontakt">
    <div class="contact-left">
      <div class="eyebrow eyebrow--light"><div class="eyebrow-line"></div><span class="eyebrow-text">Kontakt</span></div>
      <h2>Porozmawiajmy o Twojej cysternie lub flocie</h2>
      <p>Wycena, umowa serwisowa lub pilna awaria — odpowiadamy szybko i konkretnie.</p>
      <div class="cd">
        <div class="cd-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1l-2.3 2.2z" fill="#00A0E3"/></svg></div>
        <div><div class="cd-lbl">Telefon serwisowy</div><div class="cd-val"><a href="tel:795196740">795 196 740</a></div></div>
      </div>
      <div class="cd">
        <div class="cd-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="#00A0E3" stroke-width="1.5"/><polyline points="22,6 12,13 2,6" stroke="#00A0E3" stroke-width="1.5"/></svg></div>
        <div><div class="cd-lbl">E-mail</div><div class="cd-val"><a href="mailto:biuro@lngbestpartner.pl">biuro@lngbestpartner.pl</a></div></div>
      </div>
      <div class="cd">
        <div class="cd-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" stroke="#00A0E3" stroke-width="1.5"/><circle cx="12" cy="10" r="3" stroke="#00A0E3" stroke-width="1.5"/></svg></div>
        <div><div class="cd-lbl">Warsztat</div><div class="cd-val">Krzywopłoty 2A, 78-230 Karlino</div></div>
      </div>
      <div class="cd">
        <div class="cd-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><rect x="2" y="7" width="20" height="14" rx="2" stroke="#00A0E3" stroke-width="1.5"/><path d="M16 7V5a2 2 0 0 0-4 0v2" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg></div>
        <div><div class="cd-lbl">NIP</div><div class="cd-val">6722081703</div></div>
      </div>
    </div>
    <div class="contact-right">
      <h3>Wyślij zapytanie</h3>
      <form name="kontakt" method="POST" data-netlify="true">
        <input type="hidden" name="form-name" value="kontakt" />
        <input type="text" name="firma" placeholder="Imię i nazwisko / nazwa firmy" required />
        <input type="text" name="kontakt" placeholder="Telefon lub e-mail" required />
        <select name="temat">
          <option value="">Czego dotyczy zapytanie?</option>
          <option>Izolacja próżniowa</option>
          <option>Helowa detekcja nieszczelności</option>
          <option>Pomiary termowizyjne</option>
          <option>Badania ADR / UDT</option>
          <option>Serwis ciągnika siodłowego</option>
          <option>Umowa serwisowa dla floty</option>
          <option>Serwis awaryjny</option>
          <option>Inne</option>
        </select>
        <textarea name="wiadomosc" placeholder="Opisz problem lub zapytanie..."></textarea>
        <button type="submit" class="btn-blue" style="width:100%;justify-content:center">Wyślij zapytanie →</button>
      </form>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-copy">© 2025 LNG Best Partner Sp. z o.o. · NIP 6722081703 · Krzywopłoty 2A, 78-230 Karlino</div>
    <div class="footer-links">
      <a href="/polityka-prywatnosci">Polityka prywatności</a>
      <a href="/#uslugi">Usługi</a>
      <a href="https://transport-lng.pl" target="_blank" rel="noopener" class="footer-transport">↗ transport-lng.pl</a>
    </div>
  </footer>
</Base>

<style>
/* ═══ HERO ═══ */
.hero {
  position: relative;
  min-height: 620px;
  overflow: hidden;
  background: #fff;
  display: flex;
  align-items: stretch;
}
.hero-photo {
  position: absolute;
  right: 0; top: 0; bottom: 0;
  width: 58%;
  clip-path: polygon(12% 0%, 100% 0%, 100% 100%, 0% 100%);
  background: #b8c8d8;
  overflow: hidden;
}
.hero-photo img { width: 100%; height: 100%; object-fit: cover; }
.hero-fade {
  position: absolute; inset: 0;
  background: linear-gradient(to right, #fff 0%, rgba(255,255,255,.75) 22%, transparent 50%);
  z-index: 1;
}
.hero-content {
  position: relative; z-index: 2;
  padding: 90px 52px 90px 48px;
  max-width: 580px;
  display: flex; flex-direction: column; justify-content: center;
}
.hero-content h1 {
  font-size: 40px; font-weight: 800; line-height: 1.12;
  color: #0f0f1a; margin-bottom: 20px; letter-spacing: -.025em;
}
.hero-content h1 em { font-style: normal; color: #00A0E3; }
.hero-sub {
  font-size: 15px; color: #5a6a7a; line-height: 1.8;
  margin-bottom: 32px; max-width: 420px;
}
.hero-actions { display: flex; gap: 12px; margin-bottom: 48px; flex-wrap: wrap; }
.hero-stats { display: flex; gap: 32px; padding-top: 28px; border-top: 1px solid #e8eef4; }
.stat { display: flex; flex-direction: column; }
.stat-n { font-size: 26px; font-weight: 700; color: #0f0f1a; font-family: var(--font-display); }
.stat-l { font-size: 11px; color: #9aaab8; margin-top: 2px; }
.hero-badge {
  position: absolute; right: 40px; bottom: 28px; z-index: 5;
  background: #fff; border-radius: 10px; padding: 12px 18px;
  box-shadow: 0 2px 20px rgba(0,0,0,.12);
  display: flex; align-items: center; gap: 10px;
