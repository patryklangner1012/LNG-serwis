---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';

const postFiles = await Astro.glob('../content/posts/*.md');
const posts = postFiles
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime())
  .slice(0, 3);
---
<Base>
  <Nav />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <div class="eyebrow">
          <div class="eyebrow-line"></div>
          <span class="eyebrow-text">Północna Polska · Obsługa Europy</span>
        </div>
        <h1>Specjalistyczny serwis<br>cystern <em>kriogenicznych</em><br>i technologii LNG</h1>
        <p>Ponad dekada precyzji technicznej w obsłudze pojazdów i zbiorników kriogenicznych. Laserowa detekcja metanu, helowa identyfikacja nieszczelności, termowizja. Jeden partner. Pełna odpowiedzialność.</p>
        <div class="hero-btns">
          <a href="#uslugi" class="btn-dark">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Poznaj nasze usługi
          </a>
          <a href="tel:795196740" class="btn-blue">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1l-2.3 2.2z" fill="#fff"/></svg>
            795 196 740
          </a>
        </div>
        <div class="hero-stats">
          <div class="stat"><span class="stat-n">10+</span><span class="stat-l">Lat doświadczenia</span></div>
          <div class="stat"><span class="stat-n">A–Z</span><span class="stat-l">Pełen zakres obsługi</span></div>
          <div class="stat"><span class="stat-n">PL/EU</span><span class="stat-l">Zasięg mobilny</span></div>
        </div>
      </div>
      <div class="hero-photo">
        <img src="/images/hero-cysterna.jpg" alt="Serwis cystern kriogenicznych LNG Best Partner" />
        <div class="hero-badge">
          <span class="badge-dot"></span>
          <div>
            <div class="badge-title">Warsztat dostępny</div>
            <div class="badge-sub">Karlino, woj. zachodniopomorskie</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STRIP -->
  <div class="strip">
    <div class="strip-item"><span class="sdot"></span>Laserowa detekcja metanu — pierwsi w Polsce</div>
    <div class="strip-item"><span class="sdot"></span>Odbudowa izolacji próżniowej</div>
    <div class="strip-item"><span class="sdot"></span>Helowa detekcja nieszczelności</div>
    <div class="strip-item"><span class="sdot"></span>ADR klasa 2</div>
    <div class="strip-item"><span class="sdot"></span>Serwis mobilny EU</div>
  </div>

  <!-- FILARY -->
  <section class="section bg-gray" id="uslugi">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow"><div class="eyebrow-line"></div><span class="eyebrow-text">Czym się wyróżniamy</span></div>
        <h2>Standardy, które definiują branżę</h2>
        <p>Łączymy wieloletnie doświadczenie z technologiami diagnostycznymi niedostępnymi w żadnym innym warsztacie kriogenicznym w Polsce.</p>
      </div>
      <div class="grid-3">
        <div class="card card--top">
          <div class="card-num">01</div>
          <h3>Pełna obsługa — od diagnostyki po regenerację próżni</h3>
          <p>Od drobnych interwencji serwisowych po kompleksową odbudowę izolacji próżniowej — serca każdej cysterny kriogenicznej. Jeden serwis, pełna odpowiedzialność techniczna.</p>
        </div>
        <div class="card card--top">
          <div class="card-num">02</div>
          <h3>Technologie diagnostyczne niedostępne w regionie</h3>
          <p>Laserowy detektor metanu, helowa identyfikacja nieszczelności, kamera termowizyjna i nowoczesna stacja próżniowa — precyzja diagnostyki na poziomie zakładu produkcyjnego.</p>
        </div>
        <div class="card card--top">
          <div class="card-num">03</div>
          <h3>Bezpieczeństwo powierzonego mienia i personelu</h3>
          <p>Jako pierwsi w Polsce wdrożyliśmy laserową detekcję metanu w środowisku warsztatowym. Praca przy mediach kriogenicznych wymaga najwyższych standardów.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TECHNOLOGIA -->
  <section class="section bg-white" id="technologia">
    <div class="container">
      <div class="split">
        <div class="split-photo">
          <img src="/images/tech-sprzet.jpg" alt="Nowoczesny sprzęt diagnostyczny" />
        </div>
        <div class="split-text">
          <div class="eyebrow"><div class="eyebrow-line"></div><span class="eyebrow-text">Technologia i diagnostyka</span></div>
          <h2>Sprzęt, który zmienia jakość diagnozy</h2>
          <p>Każde zlecenie realizujemy z użyciem precyzyjnych narzędzi diagnostycznych, które pozwalają identyfikować problemy zanim staną się kosztownymi awariami.</p>
          <div class="tech-list">
            <div class="tech-item">
              <div class="ti-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg>
              </div>
              <div>
                <div class="ti-title">Laserowa detekcja metanu</div>
                <div class="ti-desc">Pierwsi w Polsce w środowisku warsztatowym. Ciągły monitoring w czasie rzeczywistym.</div>
              </div>
            </div>
            <div class="tech-item">
              <div class="ti-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="3" stroke="#00A0E3" stroke-width="1.5"/><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg>
              </div>
              <div>
                <div class="ti-title">Helowa detekcja nieszczelności</div>
                <div class="ti-desc">Precyzyjna identyfikacja przecieków w układach próżniowych.</div>
              </div>
            </div>
            <div class="tech-item">
              <div class="ti-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M2 12h1M21 12h1M12 2v1M12 21v1M4.93 4.93l.7.7M18.37 18.37l.7.7M4.93 19.07l.7-.7M18.37 5.63l.7-.7" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/><circle cx="12" cy="12" r="4" stroke="#00A0E3" stroke-width="1.5"/></svg>
              </div>
              <div>
                <div class="ti-title">Pomiary termowizyjne</div>
                <div class="ti-desc">Ocena stanu izolacji bez demontażu. Szybka diagnostyka, precyzyjny wynik.</div>
              </div>
            </div>
            <div class="tech-item">
              <div class="ti-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><ellipse cx="12" cy="12" rx="10" ry="10" stroke="#00A0E3" stroke-width="1.5"/><path d="M12 8v4l3 3" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg>
              </div>
              <div>
                <div class="ti-title">Stacja odbudowy izolacji próżniowej</div>
                <div class="ti-desc">Nowoczesna stacja do pełnej regeneracji naczep i zbiorników stacjonarnych.</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BEZPIECZENSTWO -->
  <section class="section bg-dark">
    <div class="container">
      <div class="safety-grid">
        <div class="safety-text">
          <div class="eyebrow eyebrow--light"><div class="eyebrow-line"></div><span class="eyebrow-text">Bezpieczeństwo</span></div>
          <h2>Pierwsi w Polsce z laserową detekcją metanu w warsztacie</h2>
          <p>W środowisku kriogenicznym nie ma miejsca na kompromisy. Wdrożyliśmy standardy ochrony, które stawiają nas w awangardzie branży.</p>
          <div class="safety-claim">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#00A0E3" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Pierwszy warsztat kriogeniczny w Polsce z laserową detekcją metanu
          </div>
        </div>
        <div class="safety-cards">
          <div class="scard">
            <div class="scard-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="#00A0E3" stroke-width="1.5" stroke-linejoin="round"/></svg></div>
            <div class="scard-title">Laserowy detektor metanu</div>
            <p class="scard-desc">Monitoring atmosfery w czasie rzeczywistym.</p>
          </div>
          <div class="scard">
            <div class="scard-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><rect x="3" y="11" width="18" height="11" rx="2" stroke="#00A0E3" stroke-width="1.5"/><path d="M7 11V7a5 5 0 0 1 10 0v4" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg></div>
            <div class="scard-title">Ochrona mienia</div>
            <p class="scard-desc">Twoja cysterna pod pełną kontrolą środowiska pracy.</p>
          </div>
          <div class="scard">
            <div class="scard-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="#00A0E3" stroke-width="1.5"/></svg></div>
            <div class="scard-title">Bezpieczeństwo personelu</div>
            <p class="scard-desc">Certyfikowane procedury i sprzęt klasy przemysłowej.</p>
          </div>
          <div class="scard">
            <div class="scard-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M9 11l3 3L22 4" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg></div>
            <div class="scard-title">Uprawnienia ADR klasa 2</div>
            <p class="scard-desc">Przygotowanie do badań UDT. Prace zgodne z przepisami ADR.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- POJAZDY -->
  <section class="section bg-gray">
    <div class="container">
      <div class="split split--rev">
        <div class="split-text">
          <div class="eyebrow"><div class="eyebrow-line"></div><span class="eyebrow-text">Serwis pojazdów ciężarowych</span></div>
          <h2>Ciągniki siodłowe — nasza druga specjalność</h2>
          <p>Równolegle z serwisem kriogenicznym prowadzimy pełnozakresową obsługę techniczną pojazdów ciężarowych. Specjalizujemy się w markach skandynawskich, jednak żaden pojazd nie jest nam obcy.</p>
          <div class="brands">
            <span class="brand brand--main">Scania</span>
            <span class="brand brand--main">Volvo</span>
            <span class="brand brand--main">Renault</span>
            <span class="brand">MAN</span>
            <span class="brand">DAF</span>
            <span class="brand">Mercedes</span>
            <span class="brand">+ inne marki</span>
          </div>
          <p class="note">Obsługujemy zarówno jednostkowe zlecenia jak i całe floty. Umowy serwisowe z priorytetowym czasem reakcji.</p>
        </div>
        <div class="split-photo">
          <img src="/images/vehicles-serwis.jpg" alt="Serwis ciągników siodłowych" />
        </div>
      </div>
    </div>
  </section>

  <!-- AKTUALNOSCI -->
  <section class="section bg-white">
    <div class="container">
      <div class="news-header">
        <div>
          <div class="eyebrow"><div class="eyebrow-line"></div><span class="eyebrow-text">Aktualności</span></div>
          <h2>Z życia warsztatu</h2>
        </div>
        <a href="/aktualnosci" class="news-more">Wszystkie wpisy →</a>
      </div>
      <div class="news-grid">
        {posts.map((post, i) => (
          <a href={post.url} class={`ncard ${i === 0 ? 'ncard--featured' : ''}`}>
            <div class="ncard-img">
              {post.frontmatter.image
                ? <img src={post.frontmatter.image} alt={post.frontmatter.title} loading="lazy" />
                : <div class="ncard-placeholder"></div>
              }
              <span class="ntag">{post.frontmatter.tag ?? 'Aktualność'}</span>
            </div>
            <div class="ncard-body">
              <div class="ndate">{new Date(post.frontmatter.date).toLocaleDateString('pl-PL', { year:'numeric', month:'long' })}</div>
              <h4>{post.frontmatter.title}</h4>
              <p>{post.frontmatter.excerpt}</p>
            </div>
          </a>
        ))}
        {posts.length === 0 && <p class="empty">Pierwsze wpisy pojawią się wkrótce.</p>}
      </div>
    </div>
  </section>

  <!-- KONTAKT -->
  <section class="section bg-split" id="kontakt">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <div class="eyebrow eyebrow--light"><div class="eyebrow-line"></div><span class="eyebrow-text">Kontakt</span></div>
          <h2>Porozmawiajmy o Twojej cysternie lub flocie</h2>
          <p>Wycena, umowa serwisowa lub pilna awaria — odpowiadamy szybko i konkretnie.</p>
          <div class="cd">
            <div class="cd-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1l-2.3 2.2z" fill="#00A0E3"/></svg></div>
            <div><div class="cd-lbl">Telefon serwisowy</div><a href="tel:795196740" class="cd-val">795 196 740</a></div>
          </div>
          <div class="cd">
            <div class="cd-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="#00A0E3" stroke-width="1.5"/><polyline points="22,6 12,13 2,6" stroke="#00A0E3" stroke-width="1.5"/></svg></div>
            <div><div class="cd-lbl">E-mail</div><a href="mailto:biuro@lngbestpartner.pl" class="cd-val">biuro@lngbestpartner.pl</a></div>
          </div>
          <div class="cd">
            <div class="cd-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" stroke="#00A0E3" stroke-width="1.5"/><circle cx="12" cy="10" r="3" stroke="#00A0E3" stroke-width="1.5"/></svg></div>
            <div><div class="cd-lbl">Warsztat</div><div class="cd-val">Krzywopłoty 2A, 78-230 Karlino</div></div>
          </div>
          <div class="cd">
            <div class="cd-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><rect x="2" y="7" width="20" height="14" rx="2" stroke="#00A0E3" stroke-width="1.5"/><path d="M16 7V5a2 2 0 0 0-4 0v2" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg></div>
            <div><div class="cd-lbl">NIP</div><div class="cd-val">6722081703</div></div>
          </div>
        </div>
        <div class="contact-form">
          <h3>Wyślij zapytanie</h3>
          <form name="kontakt" method="POST" data-netlify="true">
            <input type="hidden" name="form-name" value="kontakt" />
            <input type="text" name="firma" placeholder="Imię i nazwisko / nazwa firmy" required />
            <input type="text" name="kontakt" placeholder="Telefon lub e-mail" required />
            <select name="temat">
              <option value="">Czego dotyczy zapytanie?</option>
              <option>Izolacja próżniowa</option>
              <option>Helowa detekcja nieszczelności</option>
              <option>Pomiary termowizyjne</option>
              <option>Badania ADR / UDT</option>
              <option>Serwis ciągnika siodłowego</option>
              <option>Umowa serwisowa dla floty</option>
              <option>Serwis awaryjny</option>
              <option>Inne</option>
            </select>
            <textarea name="wiadomosc" placeholder="Opisz problem lub zapytanie..."></textarea>
            <button type="submit" class="btn-blue" style="width:100%;justify-content:center">Wyślij zapytanie →</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-copy">© 2025 LNG Best Partner Sp. z o.o. · NIP 6722081703 · Krzywopłoty 2A, 78-230 Karlino</div>
      <div class="footer-links">
        <a href="/polityka-prywatnosci">Polityka prywatności</a>
        <a href="#uslugi">Usługi</a>
        <a href="https://transport-lng.pl" target="_blank" rel="noopener" class="footer-transport">↗ transport-lng.pl</a>
      </div>
    </div>
  </footer>
</Base>

<style>
/* ── RESET & BASE ── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

.container {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 48px;
}

/* ── SECTIONS ── */
.section { padding: 80px 0; }
.bg-white { background: #fff; }
.bg-gray  { background: #f7f9fc; }
.bg-dark  { background: #0f0f1a; }
.bg-split { background: #0f0f1a; }

.section-header { margin-bottom: 48px; }
.section-header h2 { font-size: 28px; font-weight: 700; color: #0f0f1a; margin-bottom: 10px; letter-spacing: -.02em; }
.section-header p  { font-size: 14px; color: #5a6a7a; line-height: 1.75; max-width: 560px; }

/* ── EYEBROW ── */
.eyebrow { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
.eyebrow-line { width: 28px; height: 2px; background: #00A0E3; flex-shrink: 0; }
.eyebrow-text { font-size: 11px; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: #00A0E3; }
.eyebrow--light .eyebrow-line { background: rgba(255,255,255,.35); }
.eyebrow--light .eyebrow-text { color: rgba(255,255,255,.45); }

/* ── BUTTONS ── */
.btn-dark { display: inline-flex; align-items: center; gap: 8px; padding: 14px 26px; border-radius: 8px; font-size: 14px; font-weight: 600; background: #0f0f1a; color: #fff; border: none; cursor: pointer; text-decoration: none; transition: opacity .2s; }
.btn-blue { display: inline-flex; align-items: center; gap: 8px; padding: 14px 26px; border-radius: 8px; font-size: 14px; font-weight: 600; background: #00A0E3; color: #fff; border: none; cursor: pointer; text-decoration: none; transition: opacity .2s; }
.btn-dark:hover, .btn-blue:hover { opacity: .85; }

/* ── HERO ── */
.hero { background: #fff; padding: 0; }
.hero-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 48px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: center;
  min-height: 600px;
}
.hero-text { padding: 80px 0; }
.hero-text h1 {
  font-size: clamp(32px, 3.5vw, 52px);
  font-weight: 800;
  line-height: 1.1;
  color: #0f0f1a;
  margin-bottom: 20px;
  letter-spacing: -.025em;
}
.hero-text h1 em { font-style: normal; color: #00A0E3; }
.hero-text p { font-size: 15px; color: #5a6a7a; line-height: 1.8; margin-bottom: 32px; max-width: 440px; }
.hero-btns { display: flex; gap: 12px; margin-bottom: 48px; flex-wrap: wrap; }
.hero-stats { display: flex; gap: 32px; padding-top: 28px; border-top: 1px solid #e8eef4; }
.stat { display: flex; flex-direction: column; }
.stat-n { font-size: 24px; font-weight: 700; color: #0f0f1a; }
.stat-l { font-size: 11px; color: #9aaab8; margin-top: 2px; }

.hero-photo {
  position: relative;
  height: 520px;
  border-radius: 16px;
  overflow: hidden;
  background: #c0d0e0;
}
.hero-photo img { width: 100%; height: 100%; object-fit: cover; }
.hero-badge {
  position: absolute; bottom: 20px; left: 20px;
  background: #fff; border-radius: 10px; padding: 12px 16px;
  box-shadow: 0 4px 20px rgba(0,0,0,.12);
  display: flex; align-items: center; gap: 10px;
}
.badge-dot { width: 8px; height: 8px; border-radius: 50%; background: #22c55e; flex-shrink: 0; }
.badge-title { font-size: 12px; font-weight: 600; color: #0f0f1a; }
