---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';

const postFiles = await Astro.glob('../content/posts/*.md');
const posts = postFiles
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime())
  .slice(0, 3);
---
<Base>
  <Nav />

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="hero-l">
      <div class="hero-tag">
        <span class="hero-tag-dot"></span>
        Północna Polska · Zasięg usług kriogenicznych PL/EU
      </div>
      <h1>Serwis cystern <em>kriogenicznych</em><br>i pojazdów ciężarowych</h1>
      <p>Zbudowany na ponad dekadzie doświadczenia w branży LNG — serwis cystern kriogenicznych i pojazdów ciężarowych z wiedzą, którą daje codzienny kontakt z technologią kriogeniczną od środka.</p>
      <div class="hero-btns">
        <a href="#uslugi" class="btn-dark">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Poznaj usługi
        </a>
        <a href="tel:+48795196740" class="btn-blue">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1l-2.3 2.2z" fill="#fff"/></svg>
          +48 795 196 740
        </a>
      </div>
      <div class="hero-stats">
        <div class="hs"><span class="hs-n">10+</span><span class="hs-l">Lat doświadczenia</span></div>
        <div class="hs"><span class="hs-n">A–Z</span><span class="hs-l">Pełen zakres</span></div>
        <div class="hs"><span class="hs-n">PL/EU</span><span class="hs-l">Usługi kriogeniczne</span></div>
      </div>
    </div>

    <div class="hero-r">
      <div class="hero-img">
        <img src="/images/hero-cysterna.jpg" alt="Serwis cystern kriogenicznych LNG Best Partner Karlino" />
      </div>
      <div class="hero-fade"></div>
      <div class="hero-badge">
        <span class="badge-dot"></span>
        <div>
          <div class="badge-t">Warsztat dostępny</div>
          <div class="badge-s">Karlino, woj. zachodniopomorskie</div>
        </div>
      </div>
    </div>
  </section>

  <!-- STRIP -->
  <div class="strip">
    <div class="strip-track">
      <div class="si"><span class="sd"></span>Laserowa detekcja metanu</div>
      <div class="si"><span class="sd"></span>Odbudowa izolacji próżniowej</div>
      <div class="si"><span class="sd"></span>Helowa detekcja nieszczelności</div>
      <div class="si"><span class="sd"></span>ADR klasa 2 / TDT</div>
      <div class="si"><span class="sd"></span>Zasięg usług kriogenicznych PL/EU</div>
      <div class="si"><span class="sd"></span>Serwis pojazdów ciężarowych</div>
      <!-- kopia dla płynnej pętli -->
      <div class="si"><span class="sd"></span>Laserowa detekcja metanu</div>
      <div class="si"><span class="sd"></span>Odbudowa izolacji próżniowej</div>
      <div class="si"><span class="sd"></span>Helowa detekcja nieszczelności</div>
      <div class="si"><span class="sd"></span>ADR klasa 2 / TDT</div>
      <div class="si"><span class="sd"></span>Zasięg usług kriogenicznych PL/EU</div>
      <div class="si"><span class="sd"></span>Serwis pojazdów ciężarowych</div>
    </div>
  </div>

  <!-- ═══ USŁUGI — 9 kart z załącznika ═══ -->
  <section class="section bg-dark" id="uslugi">
    <div class="sh">
      <span class="stag stag-light">Zakres usług</span>
      <h2>Kompleksowy serwis — kriogeniczny i ciężarowy</h2>
      <p>Obsługujemy pełne spektrum potrzeb technicznych — od serwisu pojazdów ciężarowych, przez diagnostykę kriogeniczną, aż po mobilne pogotowie cystern LNG.</p>
    </div>
    <div class="ug">
      <div class="uc reveal d1">
        <div class="uc-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="1" y="3" width="15" height="13" rx="2" stroke="#00A0E3" stroke-width="1.5"/><path d="M16 8h4l3 4v5h-7V8z" stroke="#00A0E3" stroke-width="1.5" stroke-linejoin="round"/><circle cx="5.5" cy="18.5" r="2.5" stroke="#00A0E3" stroke-width="1.5"/><circle cx="18.5" cy="18.5" r="2.5" stroke="#00A0E3" stroke-width="1.5"/></svg></div>
        <div class="uc-n">01</div><h3>Naprawa pojazdów ciężarowych</h3><p>Kompleksowa obsługa pojazdów ciężarowych ze szczególnym uwzględnieniem marek Scania, Volvo i Renault. Serwisujemy również pojazdy innych producentów.</p>
      </div>
      <div class="uc reveal d2">
        <div class="uc-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="2" y="7" width="18" height="10" rx="2" stroke="#00A0E3" stroke-width="1.5"/><path d="M20 17h2v-4" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/><circle cx="7" cy="19" r="2" stroke="#00A0E3" stroke-width="1.5"/><circle cx="15" cy="19" r="2" stroke="#00A0E3" stroke-width="1.5"/></svg></div>
        <div class="uc-n">02</div><h3>Naprawa przyczep i naczep</h3><p>Naprawa wszelkich przyczep i naczep ciężarowych działających na systemach takich marek jak KNORR-BREMSE, WABCO, ZF, HALDEX.</p>
      </div>
      <div class="uc reveal d3">
        <div class="uc-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/><circle cx="12" cy="12" r="3" stroke="#00A0E3" stroke-width="1.5"/></svg></div>
        <div class="uc-n">03</div><h3>Serwis naczep kriogenicznych</h3><p>Specjalizujemy się w serwisie naczep kriogenicznych, obejmującym diagnostykę, naprawy oraz konserwację naczep do transportu gazów skroplonych.</p>
      </div>
      <div class="uc reveal d4">
        <div class="uc-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="#00A0E3" stroke-width="1.5"/><circle cx="12" cy="12" r="4" stroke="#00A0E3" stroke-width="1.5"/><path d="M12 3v2M12 19v2M3 12h2M19 12h2" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg></div>
        <div class="uc-n">04</div><h3>Usługi wulkanizacyjne</h3><p>Usługi wulkanizacyjne dla pojazdów ciężarowych, obejmujące wymianę oraz naprawę opon. Szybkie i profesjonalne wykonanie, dostosowane do potrzeb branży transportowej.</p>
      </div>
      <div class="uc reveal d5">
        <div class="uc-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 2a7 7 0 0 1 7 7c0 5-7 13-7 13S5 14 5 9a7 7 0 0 1 7-7z" stroke="#00A0E3" stroke-width="1.5"/><circle cx="12" cy="9" r="2.5" stroke="#00A0E3" stroke-width="1.5"/></svg></div>
        <div class="uc-n">05</div><h3>Obsługa zbiorników próżniowych</h3><p>Obsługa mobilnych i stacjonarnych zbiorników próżniowych, dbając o ciągłość sprawności technicznej oraz bezpieczeństwo użytkowania.</p>
      </div>
      <div class="uc reveal d6">
        <div class="uc-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="3" stroke="#00A0E3" stroke-width="1.5"/><ellipse cx="12" cy="12" rx="10" ry="4" stroke="#00A0E3" stroke-width="1.5"/><ellipse cx="12" cy="12" rx="10" ry="4" stroke="#00A0E3" stroke-width="1.5" transform="rotate(60 12 12)"/><ellipse cx="12" cy="12" rx="10" ry="4" stroke="#00A0E3" stroke-width="1.5" transform="rotate(120 12 12)"/></svg></div>
        <div class="uc-n">06</div><h3>Helowa detekcja nieszczelności</h3><p>Precyzyjne wykrywanie nawet najmniejszych wycieków w instalacjach i zbiornikach. Nowoczesne metody badawcze gwarantujące wysoką skuteczność i bezpieczeństwo.</p>
      </div>
      <div class="uc reveal d7">
        <div class="uc-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="5" y="2" width="14" height="20" rx="2" stroke="#00A0E3" stroke-width="1.5"/><path d="M9 7h6M9 11h6M9 15h4" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/><path d="M15 1v4M9 1v4" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg></div>
        <div class="uc-n">07</div><h3>Przygotowanie do badań TDT</h3><p>Kompleksowe przygotowanie pojazdów i urządzeń do badań TDT, obejmujące przegląd techniczny, niezbędne naprawy oraz weryfikację zgodności z wymaganiami.</p>
      </div>
      <div class="uc reveal d8">
        <div class="uc-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="#00A0E3" stroke-width="1.5" stroke-linejoin="round"/></svg></div>
        <div class="uc-n">08</div><h3>Mobilne pogotowie cystern LNG</h3><p>Mobilne pogotowie cystern LNG — szybka i profesjonalna pomoc serwisowa bezpośrednio w miejscu awarii. Sprawna diagnostyka, naprawy i minimalizacja przestojów.</p>
      </div>
      <div class="uc reveal d9">
        <div class="uc-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z" stroke="#00A0E3" stroke-width="1.5" stroke-linejoin="round"/></svg></div>
        <div class="uc-n">09</div><h3>Pomiary termowizyjne</h3><p>Pomiary termowizyjne umożliwiające ocenę stanu technicznego instalacji i urządzeń. Nowoczesna aparatura, rzetelne wyniki i szczegółowa dokumentacja z przeprowadzonych badań.</p>
      </div>
    </div>
  </section>

  <!-- ═══ TECHNOLOGIA ═══ -->
  <section class="split-tech bg-white" id="technologia">
    <div class="tech-img">
      <img src="/images/tech-pompa.jpg" alt="Pompa próżniowa serwis kriogeniczny" />
    </div>
    <div class="tech-fade"></div>
    <div class="tech-content">
      <span class="stag">Technologia i diagnostyka</span>
      <h2>Zaawansowany sprzęt diagnostyczny</h2>
      <p>Inwestujemy w technologie klasy przemysłowej. Każde zlecenie realizujemy z precyzją niedostępną w standardowym warsztacie.</p>
      <div class="tis">
        <div class="ti">
          <div class="ti-ic"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg></div>
          <div><div class="ti-t">Laserowy detektor metanu</div><div class="ti-d">Ciągły monitoring atmosfery — bezpieczeństwo mienia i personelu w czasie rzeczywistym.</div></div>
        </div>
        <div class="ti">
          <div class="ti-ic"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="3" stroke="#00A0E3" stroke-width="1.5"/><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg></div>
          <div><div class="ti-t">Helowa detekcja nieszczelności</div><div class="ti-d">Identyfikacja przecieków niedostępna metodami konwencjonalnymi.</div></div>
        </div>
        <div class="ti">
          <div class="ti-ic"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M2 12h1M21 12h1M12 2v1M12 21v1M4.93 4.93l.7.7M18.37 18.37l.7.7M4.93 19.07l.7-.7M18.37 5.63l.7-.7" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/><circle cx="12" cy="12" r="4" stroke="#00A0E3" stroke-width="1.5"/></svg></div>
          <div><div class="ti-t">Kamera termowizyjna</div><div class="ti-d">Wykrywa miejsca przebijania zimna przez poszycie zewnętrzne — tam gdzie izolacja próżniowa traci skuteczność, kamera to pokaże.</div></div>
        </div>
        <div class="ti">
          <div class="ti-ic"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><ellipse cx="12" cy="12" rx="10" ry="10" stroke="#00A0E3" stroke-width="1.5"/><path d="M12 8v4l3 3" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg></div>
          <div><div class="ti-t">Pompa próżniowa</div><div class="ti-d">Regeneracja komór izolacji próżniowych w naczepach kriogenicznych oraz zbiornikach stacjonarnych do parametrów fabrycznych.</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ BEZPIECZEŃSTWO ═══ -->
  <section class="section bg-gray">
    <div class="safety-inner">
      <div class="safety-text">
        <span class="stag">Bezpieczeństwo</span>
        <h2>Standardy bezpieczeństwa klasy przemysłowej</h2>
        <p>W środowisku kriogenicznym nie ma miejsca na kompromisy. Stosujemy laserową detekcję metanu — ciągły monitoring atmosfery roboczej chroni zarówno powierzone nam mienie, jak i nasz personel.</p>
        <div class="sclaim">
          <div class="sc-ck">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          Laserowa detekcja metanu w środowisku warsztatowym
        </div>
      </div>
      <div class="scards">
        <div class="scard">
          <div class="scard-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="#00A0E3" stroke-width="1.5" stroke-linejoin="round"/></svg></div>
          <div class="scard-t">Laserowy detektor metanu</div>
          <p class="scard-d">Monitoring atmosfery — wykrycie zagrożenia zanim wystąpi.</p>
        </div>
        <div class="scard">
          <div class="scard-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><rect x="3" y="11" width="18" height="11" rx="2" stroke="#00A0E3" stroke-width="1.5"/><path d="M7 11V7a5 5 0 0 1 10 0v4" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg></div>
          <div class="scard-t">Ochrona mienia klienta</div>
          <p class="scard-d">Twoja cysterna w pełni kontrolowanym środowisku pracy.</p>
        </div>
        <div class="scard">
          <div class="scard-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="#00A0E3" stroke-width="1.5"/></svg></div>
          <div class="scard-t">Bezpieczeństwo personelu</div>
          <p class="scard-d">Certyfikowane procedury i sprzęt klasy przemysłowej.</p>
        </div>
        <div class="scard">
          <div class="scard-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M9 11l3 3L22 4" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" stroke="#00A0E3" stroke-width="1.5" stroke-linecap="round"/></svg></div>
          <div class="scard-t">Uprawnienia TDT klasa 2</div>
          <p class="scard-d">Uprawnienie TDT do przygotowywania cystern kriogenicznych klasy 2 do badań technicznych.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ POJAZDY ═══ -->
  <section class="split-vehicles bg-white">
    <div class="vehicles-img">
      <img src="/images/vehicles-serwis.jpg" alt="Serwis ciągników siodłowych Scania Volvo Renault Karlino" />
    </div>
    <div class="vehicles-fade"></div>
    <div class="vehicles-content">
      <span class="stag">Serwis pojazdów ciężarowych</span>
      <h2>Ciągniki siodłowe — nasza druga specjalność</h2>
      <p>Pełnozakresowa obsługa techniczna pojazdów ciężarowych i naczep. Specjalizujemy się w markach skandynawskich — ale serwisujemy każdą markę bez wyjątku.</p>
      <div class="brands">
        <span class="bm">Scania</span><span class="bm">Volvo</span><span class="bm">Renault</span>
        <span class="bs">MAN</span><span class="bs">DAF</span><span class="bs">Mercedes</span><span class="bs">+ inne</span>
      </div>
      <p class="vnote">Umowy serwisowe dla flot · Priorytetowy czas reakcji · Dedykowany kontakt techniczny</p>
    </div>
  </section>

  <!-- ═══ GALERIA ═══ -->
  <section class="section bg-gray" id="galeria">
    <h2 class="gal-title">Galeria</h2>
    <p class="gal-sub">Zdjęcia z warsztatu i realizacji</p>
    <div class="gg">
      <div class="gi big"><img src="/images/galeria-1.jpg" alt="Realizacja serwis kriogeniczny" /><div class="gi-cap">Realizacja — serwis kriogeniczny</div></div>
      <div class="gi"><img src="/images/galeria-2.jpg" alt="Warsztat LNG Best Partner" /><div class="gi-cap">Warsztat LNG Best Partner</div></div>
      <div class="gi"><img src="/images/galeria-3.jpg" alt="Serwis cystern" /><div class="gi-cap">Serwis cystern</div></div>
      <div class="gi"><img src="/images/galeria-4.jpg" alt="Pompa próżniowa" /><div class="gi-cap">Pompa próżniowa</div></div>
      <div class="gi"><img src="/images/galeria-5.jpg" alt="Serwis pojazdów" /><div class="gi-cap">Serwis pojazdów ciężarowych</div></div>
    </div>
  </section>

  <!-- ═══ AKTUALNOŚCI ═══ -->
  <section class="section bg-white">
    <div class="news-hdr">
      <div>
        <span class="stag">Aktualności</span>
        <h2 class="news-title">Z życia warsztatu</h2>
      </div>
      <a href="/aktualnosci" class="news-more">
        Wszystkie wpisy
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="#00A0E3" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
    <div class="ng">
      {posts.map((post, i) => (
        <a href={post.url} class={`nc ${i === 0 ? 'big' : ''}`}>
          <div class="nc-img">
            {post.frontmatter.image
              ? <img src={post.frontmatter.image} alt={post.frontmatter.title} loading="lazy" />
              : <div class="nc-ph"></div>
            }
            <span class="nc-tag">{post.frontmatter.tag ?? 'Aktualność'}</span>
          </div>
          <div class="nc-body">
            <div class="nc-date">{new Date(post.frontmatter.date).toLocaleDateString('pl-PL', { year:'numeric', month:'long' })}</div>
            <h4>{post.frontmatter.title}</h4>
            <p>{post.frontmatter.excerpt}</p>
          </div>
        </a>
      ))}
      {posts.length === 0 && (
        <p class="empty">Pierwsze wpisy pojawią się wkrótce.</p>
      )}
    </div>
  </section>

  <!-- ═══ KONTAKT ═══ -->
  <section class="section bg-dark" id="kontakt">
    <div class="contact-inner">
      <div class="ci">
        <span class="stag stag-light">Kontakt</span>
        <h2>Porozmawiajmy o Twojej cysternie lub flocie</h2>
        <p>Wycena, umowa serwisowa lub pilna awaria — odpowiadamy szybko i konkretnie.</p>
        <div class="cd">
          <div class="cd-ic"><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1l-2.3 2.2z" fill="#00A0E3"/></svg></div>
          <div><div class="cd-l">Telefon serwisowy</div><a href="tel:+48795196740" class="cd-v">+48 795 196 740</a></div>
        </div>
        <div class="cd">
