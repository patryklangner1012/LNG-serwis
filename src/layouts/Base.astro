---
import '../styles/global.css';
const { title = 'LNG Best Partner Serwis', description = 'Specjalistyczny serwis cystern kriogenicznych i pojazdów ciężarowych. Laserowa detekcja metanu, izolacja próżniowa, serwis Scania Volvo Renault. Karlino, Polska.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta name="theme-color" content="#00A0E3" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body>
  <slot />
</body>
</html>
